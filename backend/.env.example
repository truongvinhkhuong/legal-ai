# ============================================================
# Legal RAG Backend — Environment Variables
# Copy to .env and fill in your values
# ============================================================

# --- App ---
APP_ENV=development                    # development | staging | production
LOG_LEVEL=INFO
BACKEND_CORS_ORIGINS=["http://localhost:3000"]

# --- PostgreSQL ---
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/legal_rag

# --- Cache & Sessions (Redis) ---
REDIS_URL=redis://localhost:6379/0

# --- LLM: DeepSeek (primary) ---
DEEPSEEK_API_KEY=sk-xxx
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
LLM_TEMPERATURE=0.05

# --- LLM: OpenAI (fallback) ---
OPENAI_API_KEY=sk-xxx
FALLBACK_MODEL=gpt-4o-mini

# --- Embedding: Voyage AI ---
VOYAGE_API_KEY=pa-xxx
EMBEDDING_MODEL=voyage-3.5-lite
EMBEDDING_DIM=1024

# --- Vector DB: Qdrant ---
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=legal_chunks

# --- Reranker ---
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# --- Retrieval ---
RETRIEVAL_TOP_K=20
RERANK_TOP_N=5

# --- Chunking ---
CHUNK_MAX_TOKENS=1500
CHUNK_OVERLAP_TOKENS=200
SENTENCE_CHUNK_SIZE=1024

# --- Ingestion ---
SKIP_ENRICHMENT=false
ENRICHMENT_CONCURRENCY=5
LLAMA_CLOUD_API_KEY=

# --- Query Decomposition ---
DECOMPOSITION_ENABLED=true
DECOMPOSITION_MAX_SUB_QUESTIONS=4

# --- Auth (JWT) ---
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
JWT_REFRESH_EXPIRE_DAYS=7
